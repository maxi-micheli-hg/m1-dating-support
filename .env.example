# Required
OPENAI_API_KEY=sk-...

# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional — umbral mínimo de confianza del especialista (0.0–1.0)
# Si la confianza está por debajo, se añade "requiere_revision_humana" a las acciones
INTENT_MIN_CONFIDENCE=0.60

# Optional — LangSmith observability (https://smith.langchain.com)
# Poner LANGCHAIN_TRACING_V2=true solo si tenés una API key válida de LangSmith
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=m1-dating-support
